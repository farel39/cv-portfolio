---
import Icon from './Icon.astro';
---

<section id="contact" class="py-32 px-6 reveal">
  <div class="max-w-2xl mx-auto text-center">
    <p class="font-mono text-accent text-sm mb-4">06. What's next</p>
    <h3 class="text-4xl md:text-5xl font-bold mb-6" style="color: var(--color-text);">
      Get in touch.
    </h3>
    <p class="leading-relaxed mb-10" style="color: var(--color-text-muted);">
      Looking for internships starting around summer 2026, especially fullstack
      or ML / data engineering roles. Also open to teaming up for competitions.
      Either way, send me an email.
    </p>

    <a href="mailto:argyafarel.kasyara@gmail.com" class="btn text-base px-8 py-4">
      Say hi <Icon name="arrow" size={16} />
    </a>

    <div class="mt-12 flex justify-center gap-6" style="color: var(--color-text-dim);">
      <a href="https://github.com/farel39" target="_blank" rel="noopener" aria-label="GitHub" class="hover:text-accent transition">
        <Icon name="github" size={22} />
      </a>
      <a href="https://www.linkedin.com/in/argya-farel-kasyara" target="_blank" rel="noopener" aria-label="LinkedIn" class="hover:text-accent transition">
        <Icon name="linkedin" size={22} />
      </a>
      <a href="mailto:argyafarel.kasyara@gmail.com" aria-label="Email" class="hover:text-accent transition">
        <Icon name="mail" size={22} />
      </a>
    </div>

    <p class="mt-8 font-mono text-xs" style="color: var(--color-text-dim);">
      argyafarel.kasyara@gmail.com
    </p>
  </div>
</section>
