---
// Small inline icon set. Add a new icon by extending the `paths` map.
// Keeps the bundle tiny. No icon library, no extra deps.
type IconName =
  | 'folder' | 'globe' | 'gamepad' | 'car' | 'shield' | 'layout'
  | 'cpu' | 'database' | 'flask' | 'graph'
  | 'github' | 'gitlab' | 'linkedin' | 'mail' | 'arrow' | 'sun' | 'moon' | 'link'
  | 'chevron-down' | 'sparkles';

interface Props {
  name: IconName;
  size?: number;
  class?: string;
  'aria-label'?: string;
}

const { name, size = 20, class: className = '', 'aria-label': ariaLabel } = Astro.props;

const paths: Record<IconName, string> = {
