  <p class="mt-2 opacity-70">
    Source on{' '}
    <a href="https://github.com/farel39/cv-portfolio" target="_blank" rel="noopener" class="link-underline">
      github.com/farel39/cv-portfolio
    </a>
  </p>
</footer>
