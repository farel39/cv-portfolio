---
const groups = [
  { title: 'Languages', items: ['Java', 'Python', 'TypeScript', 'JavaScript', 'Dart', 'SQL', 'GDScript'] },
  { title: 'Backend',   items: ['Spring Boot', 'Django', 'FastAPI', 'PostgreSQL', 'Neo4j', 'Docker'] },
  { title: 'Frontend',  items: ['Next.js / React', 'Astro', 'Tailwind CSS', 'HTML / CSS'] },
  { title: 'Mobile',    items: ['Flutter (iOS / Android)'] },
  { title: 'ML / Data', items: ['PyTorch', 'scikit-learn', 'CatBoost', 'XGBoost', 'LightGBM', 'HF Transformers', 'Pandas / NumPy'] },
];
---

<section
  id="skills"
  class="py-28 px-6 reveal"
  style="background: color-mix(in oklch, var(--color-surface) 40%, transparent); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);"
>
  <div class="max-w-5xl mx-auto">
    <h3 class="section-h">
      <span class="step">03.</span>Tech I work with
    </h3>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {groups.map((g) => (
        <div class="card p-5">
          <h4 class="font-mono text-sm text-accent mb-3 tracking-wide">{g.title}</h4>
          <ul class="space-y-2 text-sm" style="color: var(--color-text);">
            {g.items.map((it) => (
              <li class="flex items-start gap-2">
                <span class="text-accent mt-1" aria-hidden="true">▸</span>
                <span>{it}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
