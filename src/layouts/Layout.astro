---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Argya Farel Kasyara · CS @ Fasilkom UI',
  description = 'Computer Science undergrad at Universitas Indonesia. Full-stack engineer and ML/AI competitor.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'http://localhost:4321').toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- OG -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Favicon: inline SVG, no extra HTTP request -->
    <link
      rel="icon"
      type="image/svg+xml"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' rx='20' fill='%230b1220'/%3E%3Ctext x='50' y='68' font-family='JetBrains Mono,monospace' font-size='52' font-weight='700' text-anchor='middle' fill='%2322d3ee'%3Ea%3C/text%3E%3C/svg%3E"
    />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Set theme before paint to avoid flash. -->
    <script is:inline>
      (() => {
        const stored = localStorage.getItem('theme');
        if (stored === 'light') document.documentElement.classList.add('light');
      })();
    </script>

    <ClientRouter />
  </head>

  <body class="min-h-screen">
    <slot />
  </body>
</html>
